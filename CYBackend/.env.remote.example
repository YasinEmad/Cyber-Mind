# Remote auth configuration (do NOT commit real secrets)
# Enable backend to verify tokens via remote API instead of local Firebase service account
USE_REMOTE_AUTH=true
REMOTE_AUTH_BASE=https://cyber-mind.onrender.com/api

# Optional: keep or remove existing Firebase service account vars
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"cyber-mind-6f341",...}'
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
